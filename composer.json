{
    "name": "freeworld/job-finder",
    "description": "A local AI-driven pipeline designed to scrape and evaluate job listings.",
    "type": "project",
    "require": {
        "php": ">=8.1",
        "ext-curl": "*",
        "ext-json": "*",
        "freeworld/php-jobspy": "*"
    },
    "minimum-stability": "dev",
    "repositories": [
        {
            "type": "path",
            "url": "php-jobspy"
        }
    ],
    "autoload": {
        "psr-4": {
            "FreeworldJobFinder\\": "src/"
        }
    }
}
